{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": ".server-dist",
    "rootDir": "."
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules"]
}
